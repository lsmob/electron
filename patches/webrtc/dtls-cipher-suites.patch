From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Threema GmbH <security@threema.ch>
Date: Mon, 4 May 2026 12:00:00 +0000
Subject: fix: harden DTLS cipher suite configuration

Force DTLS 1.3 enabled and restrict cipher suites to ECDHE-ECDSA with
CHACHA20-POLY1305, AES256-GCM, and AES128-GCM. Limit ephemeral key exchange
to X25519, X25519-MLKEM768, SECP256R1, SECP384R1, and SECP521R1.

diff --git a/rtc_base/openssl_stream_adapter.cc b/rtc_base/openssl_stream_adapter.cc
index a40c4ec6dc6bc76125db476a6ae1b7578d9005d7..b1e2438a38782585de404bd5b3225faf0444b596 100644
--- a/rtc_base/openssl_stream_adapter.cc
+++ b/rtc_base/openssl_stream_adapter.cc
@@ -122,11 +122,7 @@ uint16_t GetMaxVersion(SSLMode ssl_mode, SSLProtocolVersion version) {
         case SSL_PROTOCOL_TLS_12:
           return TLS1_2_VERSION;
         case SSL_PROTOCOL_TLS_13:
-#ifdef TLS1_3_VERSION
           return TLS1_3_VERSION;
-#else
-          return TLS1_2_VERSION;
-#endif
       }
     case SSL_MODE_DTLS:
       switch (version) {
@@ -136,15 +132,14 @@ uint16_t GetMaxVersion(SSLMode ssl_mode, SSLProtocolVersion version) {
           return DTLS1_2_VERSION;
         case SSL_PROTOCOL_NOT_GIVEN:
         case SSL_PROTOCOL_DTLS_13:
-#ifdef DTLS1_3_VERSION
-          return DTLS1_3_VERSION;
-#else
           return DTLS1_2_VERSION;
-#endif
       }
   }
 }
 
+constexpr int kForceDtls13Enabled = 1;
+constexpr int kForceDtls13Only = 2;
+
 #ifdef OPENSSL_IS_BORINGSSL
 std::string GetOpenSslError() {
   std::string error;
@@ -307,7 +302,8 @@ OpenSSLStreamAdapter::OpenSSLStreamAdapter(
       ssl_(nullptr),
       ssl_ctx_(nullptr),
       ssl_mode_(SSL_MODE_DTLS),
-      ssl_max_version_(MAX_SSL_PROTOCOL_DTLS),
+      ssl_max_version_(SSL_PROTOCOL_DTLS_12),
+      force_dtls_13_(kForceDtls13Enabled),
       disable_ssl_group_ids_(
           env_.has_value() &&
           env_->field_trials().IsEnabled("WebRTC-DisableSslGroupIds")) {
@@ -411,11 +407,9 @@ SSLProtocolVersion OpenSSLStreamAdapter::GetSslVersion() const {
     } else if (ssl_version == DTLS1_2_VERSION) {
       return SSL_PROTOCOL_DTLS_12;
     }
-#ifdef DTLS1_3_VERSION
     if (ssl_version == DTLS1_3_VERSION) {
       return SSL_PROTOCOL_DTLS_13;
     }
-#endif
   } else {
     if (ssl_version == TLS1_VERSION) {
       return SSL_PROTOCOL_TLS_10;
@@ -424,11 +418,9 @@ SSLProtocolVersion OpenSSLStreamAdapter::GetSslVersion() const {
     } else if (ssl_version == TLS1_2_VERSION) {
       return SSL_PROTOCOL_TLS_12;
     }
-#ifdef TLS1_3_VERSION
     if (ssl_version == TLS1_3_VERSION) {
       return SSL_PROTOCOL_TLS_13;
     }
-#endif
   }
 
   return SSL_PROTOCOL_NOT_GIVEN;
@@ -1157,6 +1149,12 @@ SSL_CTX* OpenSSLStreamAdapter::SetupSSLContext() {
   auto min_version =
       ssl_mode_ == SSL_MODE_DTLS ? DTLS1_2_VERSION : TLS1_2_VERSION;
   auto max_version = GetMaxVersion(ssl_mode_, ssl_max_version_);
+  if (force_dtls_13_ == kForceDtls13Enabled) {
+    max_version = DTLS1_3_VERSION;
+  } else if (force_dtls_13_ == kForceDtls13Only) {
+    min_version = DTLS1_3_VERSION;
+    max_version = DTLS1_3_VERSION;
+  }
 
   SSL_CTX_set_min_proto_version(ctx, min_version);
   SSL_CTX_set_max_proto_version(ctx, max_version);
@@ -1203,10 +1201,10 @@ SSL_CTX* OpenSSLStreamAdapter::SetupSSLContext() {
   // remove HMAC-SHA256 and HMAC-SHA384 cipher suites, not GCM cipher suites
   // with SHA256 or SHA384 as the handshake hash.
   // This matches the list of SSLClientSocketImpl in Chromium.
-  SSL_CTX_set_cipher_list(
-      ctx,
-      "DEFAULT:!NULL:!aNULL:!SHA256:!SHA384:!aECDH:!AESGCM+AES256:!aPSK:!3DES");
-
+  SSL_CTX_set_cipher_list(ctx,
+                          "ECDHE-ECDSA-CHACHA20-POLY1305:"
+                          "ECDHE-ECDSA-AES256-GCM-SHA384:"
+                          "ECDHE-ECDSA-AES128-GCM-SHA256");
   if (!srtp_ciphers_.empty()) {
     if (SSL_CTX_set_tlsext_use_srtp(ctx, srtp_ciphers_.c_str())) {
       SSL_CTX_free(ctx);
@@ -1440,11 +1438,7 @@ void OpenSSLStreamAdapter::EnableTimeCallbackForTesting() {
 }
 
 SSLProtocolVersion OpenSSLStreamAdapter::GetMaxSupportedDTLSProtocolVersion() {
-#if defined(OPENSSL_IS_BORINGSSL) && defined(DTLS1_3_VERSION)
   return SSL_PROTOCOL_DTLS_13;
-#else
-  return SSL_PROTOCOL_DTLS_12;
-#endif
 }
 
 bool OpenSSLStreamAdapter::SetSslGroupIds(const std::vector<uint16_t>& groups) {
diff --git a/rtc_base/ssl_stream_adapter.cc b/rtc_base/ssl_stream_adapter.cc
