--- a/rtc_base/ssl_stream_adapter.cc
+++ b/rtc_base/ssl_stream_adapter.cc
@@ -125,25 +125,9 @@ SSLStreamAdapter::GetEphemeralKeyExchangeCipherGroupName(uint16_t group_id) {
 std::set<uint16_t>
 SSLStreamAdapter::GetSupportedEphemeralKeyExchangeCipherGroups() {
   return {
-  // It would be nice if BoringSSL had a function like this!
-#ifdef SSL_GROUP_SECP224R1
-      SSL_GROUP_SECP224R1,
